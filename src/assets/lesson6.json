  "grammar": [
    {
      "title": "Futur mit „werden“",
      "rules": "German uses **werden + Infinitiv** to talk about the future, especially for plans/predictions.\n\n**Form:** ich **werde** gehen, du **wirst** gehen, er/sie/es **wird** gehen, wir **werden** gehen, ihr **werdet** gehen, sie/Sie **werden** gehen.\n\nExamples from the lesson context:\n- Ich **werde** morgen zum Arzt **gehen**.\n- Wir **werden** Sie gleich **operieren**.\n- Du **wirst** bald wieder **gesund werden**.",
      "exercises": [
        [
          "Setze „werden“ richtig ein: „Ich ___ morgen in die Notaufnahme ___ (gehen).“",
          ["werde … gehen", "wirst … gehen", "wird … gehen", "werden … gehen"],
          "werde … gehen",
          "1. Person Singular → ich **werde**.",
          "ICH = WERDE.",
          "‘werden + Infinitiv’ forms the future: ich werde gehen."
        ],
        [
          "Welche Form passt? „Sie (du) ___ gleich untersucht ___.“",
          [
            "wirst … werden",
            "wirst … werden (untersucht)",
            "wirst …",
            "wirst … (werden)"
          ],
          "wirst … werden (untersucht)",
          "Achte: Passiv-Formen sind möglich, aber hier reicht: „Du wirst …“. (B1: Fokus ‘wirst’).",
          "DU = WIRST.",
          "Choose ‘wirst’ for ‘du’. In hospital context you often hear ‘Du wirst gleich …’."
        ],
        [
          "Korrigiere den Satz: „Wir wird Sie operieren.“",
          [
            "Wir werden Sie operieren.",
            "Wir wirst Sie operieren.",
            "Wir werde Sie operieren.",
            "Wir wurden Sie operieren."
          ],
          "Wir werden Sie operieren.",
          "wir → **werden**",
          "WIR = WERDEN.",
          "Subject ‘wir’ needs ‘werden’."
        ],
        [
          "Welche Aussage ist korrekt?",
          [
            "Er werde morgen nach Hause gehen.",
            "Er wird morgen nach Hause gehen.",
            "Er werden morgen nach Hause gehen.",
            "Er wirst morgen nach Hause gehen."
          ],
          "Er wird morgen nach Hause gehen.",
          "er → **wird**",
          "ER = WIRD.",
          "3rd person singular takes ‘wird’."
        ],
        [
          "Ergänze: „Ihr ___ bald wieder Sport ___ (machen).“",
          [
            "werdet … machen",
            "werden … machen",
            "wirst … machen",
            "wird … machen"
          ],
          "werdet … machen",
          "ihr → **werdet**",
          "IHR = WERDET.",
          "2nd person plural uses ‘werdet’ + infinitive."
        ]
      ]
    },
    {
      "title": "Satz mit „um … zu“ und Frage „Wozu?“",
      "rules": "Use **um … zu + Infinitiv** to express purpose (same subject in both parts).\n- Tim bringt den Laptop mit, **um** Filme **zu sehen**.\n- Celia braucht das Ladekabel, **um** ihr Handy **aufzuladen**.\n\nAsk about purpose with **Wozu …?**\n- **Wozu** brauchst du den Laptop? – **Um** Filme zu sehen.",
      "exercises": [
        [
          "Wähle die richtige Ergänzung: „Tim bringt Kopfhörer mit, ___ Celia Musik hören kann.“",
          ["um", "um … zu", "wozu", "bis"],
          "um … zu",
          "Ziel/Absicht + Infinitiv mit „zu“.",
          "UM = ZWECK.",
          "Use ‘um … zu’ to express purpose."
        ],
        [
          "Ordne richtig: „Celia braucht das Ladekabel, ___ .“",
          [
            "um ihr Handy aufzuladen",
            "wozu ihr Handy aufzuladen",
            "bis ihr Handy aufzuladen",
            "um ihr Handy aufladen"
          ],
          "um ihr Handy aufzuladen",
          "Infinitiv mit **zu**: auf**zu**laden.",
          "AUFLADEN → AUFZULADEN.",
          "After ‘um’ you need ‘zu + infinitive’ (often inside separable verbs)."
        ],
        [
          "Welche Frage passt? Antwort: „Um Filme zu sehen.“",
          [
            "Wohin brauchst du den Laptop?",
