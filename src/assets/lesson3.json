  "grammar": [
    {
      "title": "Relativpronomen im Akkusativ",
      "rules": "Relative clauses describe a noun and require commas. In Akkusativ:\n- der → den\n- die → die\n- das → das\nExample: Das ist der Vertrag, den ich kündige.",
      "exercises": [
        [
          "Setzen Sie ein: Das ist der Betrag, ___ ich überweise.",
          ["der", "den", "die", "das"],
          "den",
          "Betrag = maskulin",
          "der→den",
          "Masculine accusative → den"
        ],
        [
          "Richtig? Die Rechnung die ich bekomme ist falsch.",
          ["Ja", "Nein"],
          "Nein",
          "Komma fehlt",
          "Relativsatz braucht Komma",
          "Comma required"
        ],
        [
          "Setzen Sie ein: Das ist die Karte, ___ ich verloren habe.",
          ["die", "den", "das"],
          "die",
          "Karte = feminin",
          "die bleibt die",
          "Feminine accusative"
        ],
        [
          "Welche Form? Das ist das Konto, ___ ich eröffne.",
          ["das", "den", "die"],
          "das",
          "Konto = neutrum",
          "das bleibt das",
          "Neuter accusative"
        ],
        [
          "Kommas? Der Kunde der wartet ist nervös.",
          [
            "Der Kunde, der wartet, ist nervös.",
            "Der Kunde der wartet ist nervös."
          ],
          "Der Kunde, der wartet, ist nervös.",
          "Relativsatz mitten im Satz",
          "2 Kommas",
          "Clause separation"
        ]
      ]
    },

    {
      "title": "Reflexive Verben (Akkusativ / Dativ)",
      "rules": "If no other Akkusativ object → reflexive Akkusativ (mich). If Akkusativ object exists → reflexive Dativ (mir).\nExample: Ich ärgere mich. / Ich kaufe mir ein Handy.",
      "exercises": [
        [
          "Ich ärgere ___ über die Kosten.",
          ["mich", "mir"],
          "mich",
          "kein Objekt",
          "ohne Objekt = Akk",
          "Accusative reflexive"
        ],
        [
          "Ich kaufe ___ einen Rechner.",
          ["mich", "mir"],
          "mir",
          "Rechner = Objekt",
          "mit Objekt = Dat",
          "Dative reflexive"
        ],
        [
          "Wir überlegen ___ den Tarif.",
          ["uns", "unsere"],
          "uns",
          "reflexiv",
          "wir→uns",
          "Correct reflexive"
        ],
        [
          "Er erinnert ___ an den Termin.",
          ["sich", "ihn"],
          "sich",
          "reflexives Verb",
          "er→sich",
          "Reflexive verb"
        ],
        [
          "Du wünschst ___ eine neue Karte.",
          ["dich", "dir"],
          "dir",
          "Karte = Objekt",
          "mit Objekt = Dat",
          "Dative reflexive"
        ]
      ]
    },

    {
